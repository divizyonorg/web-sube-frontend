@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model MyApp.Web.ViewModels.Components.SelectViewModel
@{ Layout = null; }

@* Select componenti — TOM Select entegrasyonu ve stillendirme eklenecek. *@
<div>
    @if (!string.IsNullOrEmpty(Model.Label))
    {
        <label for="@Model.Name">@Model.Label</label>
    }
    <select id="@Model.Name" name="@Model.Name">
        @if (!string.IsNullOrEmpty(Model.Placeholder))
        {
            <option value="">@Model.Placeholder</option>
        }
        @foreach (var option in Model.Options)
        {
            <option value="@option.Value" selected="@(option.Value == Model.SelectedValue)">@option.Label</option>
        }
    </select>
</div>
