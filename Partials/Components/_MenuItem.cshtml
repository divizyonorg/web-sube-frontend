@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model MyApp.Web.ViewModels.Components.MenuItemViewModel
@{ Layout = null; }

@* Sidebar menü öğesi — stillendirme detayları eklenecek. *@
<a href="@Model.Href" data-active="@(Model.IsActive ? "true" : "false")">
    @if (!string.IsNullOrEmpty(Model.IconClass))
    {
        <i class="@Model.IconClass"></i>
    }
    <span>@Model.Label</span>
</a>
