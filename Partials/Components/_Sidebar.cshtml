@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model MyApp.Web.ViewModels.Components.SidebarViewModel
@{ Layout = null; }

<div x-data="{ theme: 'light' }"
     style="box-sizing: border-box; position: absolute; width: 260px; height: 811px; left: 0; top: 85px; background: rgba(255,255,255,0.00001); border-right: 1px solid rgba(46,109,248,0.25); box-shadow: 2px 0px 12px rgba(0,0,0,0.06);">

    <div style="display: flex; flex-direction: column; align-items: flex-start; padding: 0; width: 259px; height: 811px; background: #E6F7FF;">

        @* ── Collapse toggle ────────────────────────────────────── *@
        <button type="button"
                style="display: flex; flex-direction: column; align-items: flex-start; padding: 20px 20px 8px 219px; width: 259px; height: 56px; border-radius: 14px; background: transparent; border: none; cursor: pointer; box-sizing: border-box; flex-shrink: 0;">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="2.5" y="2.5" width="15" height="15" rx="2" stroke="#0056B3" stroke-width="1.667"/>
                <path d="M7.5 2.5V17.5" stroke="#0056B3" stroke-width="1.667"/>
                <path d="M10.83 7.5H13.33" stroke="#0056B3" stroke-width="1.667" stroke-linecap="round"/>
            </svg>
        </button>

        @* ── Search ──────────────────────────────────────────────── *@
        <div style="display: flex; flex-direction: column; align-items: flex-start; padding: 0 12px; width: 259px; height: 42.89px; flex-shrink: 0;">
            <div style="display: flex; flex-direction: row; align-items: center; padding: 8px 12px; gap: 8px; width: 235px; height: 34.89px; background: #FFFFFF; border: 1px solid #DCE3FB; border-radius: 9999px; box-sizing: border-box;">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink: 0;">
                    <circle cx="6.5" cy="6.5" r="4.5" stroke="#7A94B8" stroke-width="1.333"/>
                    <path d="M10.5 10.5L13.5 13.5" stroke="#7A94B8" stroke-width="1.333" stroke-linecap="round"/>
                </svg>
                <input type="text"
                       placeholder="@Model.SearchPlaceholder"
                       style="background: transparent; border: none; outline: none; font-family: 'Poppins'; font-weight: 400; font-size: 13px; line-height: 17px; color: #7A94B8; width: 100%;"
                       placeholder-style="color:#7A94B8" />
            </div>
        </div>

        @* ── Navigation ──────────────────────────────────────────── *@
        <nav style="display: flex; flex-direction: column; align-items: flex-start; padding: 4px 8px; gap: 2px; width: 259px; flex: 1 1 0; overflow: hidden;">
            @foreach (var item in Model.Items)
            {
                var isActive   = item.IsActive;
                var iconColor  = isActive ? "#FFFFFF" : "#1B4092";
                var linkStyle  = isActive
                    ? "display:flex;flex-direction:row;align-items:center;padding:10px 12px;gap:12px;width:243px;height:38px;background:linear-gradient(90deg,#0056B3 0%,#2E6DF8 100%);box-shadow:0px 1px 3px rgba(0,0,0,0.1),0px 1px 2px -1px rgba(0,0,0,0.1);border-radius:14px;text-decoration:none;box-sizing:border-box;"
                    : "display:flex;flex-direction:row;align-items:center;padding:10px 12px;gap:12px;width:243px;height:38px;border-radius:14px;text-decoration:none;box-sizing:border-box;";
                var labelStyle = isActive
                    ? "font-family:'Poppins';font-weight:600;font-size:13.5px;line-height:18px;color:#FFFFFF;"
                    : "font-family:'Poppins';font-weight:400;font-size:13.5px;line-height:18px;color:#003F75;";

                <a href="@item.Href" style="@linkStyle">
                    @switch (item.Icon)
                    {
                        case MyApp.Web.ViewModels.Components.SidebarIcon.Home:
                            @* Dashboard grid: 4 dikdörtgen (spec'ten birebir) *@
                            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;">
                                <rect x="2.25" y="2.25" width="5.25" height="6.75" rx="1" stroke="@iconColor" stroke-width="1.5"/>
                                <rect x="10.5" y="2.25" width="5.25" height="3.75" rx="1" stroke="@iconColor" stroke-width="1.5"/>
                                <rect x="10.5" y="9"    width="5.25" height="6.75" rx="1" stroke="@iconColor" stroke-width="1.5"/>
                                <rect x="2.25" y="12"   width="5.25" height="3.75" rx="1" stroke="@iconColor" stroke-width="1.5"/>
                            </svg>
                            break;
                        case MyApp.Web.ViewModels.Components.SidebarIcon.CreditReport:
                            @* Katlanmış köşeli döküman *@
                            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;">
                                <path d="M3 1.5h7.5l4.5 4.5v10.5a.75.75 0 01-.75.75H3.75A.75.75 0 013 16.5V1.5z" stroke="@iconColor" stroke-width="1.5"/>
                                <path d="M10.5 1.5v4.5H15" stroke="@iconColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M6 9.75h6M6 12.75h4.5" stroke="@iconColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                            break;
                        case MyApp.Web.ViewModels.Components.SidebarIcon.Offers:
                            @* Fiyat etiketi *@
                            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;">
                                <path d="M2.25 9.97l5.78-5.78h4.47v4.47L6.75 14.44a1.5 1.5 0 01-2.12 0L2.25 12.09a1.5 1.5 0 010-2.12z" stroke="@iconColor" stroke-width="1.5"/>
                                <circle cx="11.25" cy="7.5" r="0.75" fill="@iconColor"/>
                            </svg>
                            break;
                        case MyApp.Web.ViewModels.Components.SidebarIcon.Advisor:
                            @* Kredi kartı *@
                            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;">
                                <rect x="1.5" y="3.75" width="15" height="10.5" rx="1.5" stroke="@iconColor" stroke-width="1.5"/>
                                <path d="M1.5 7.5h15" stroke="@iconColor" stroke-width="1.5"/>
                                <path d="M4.5 11.25h3" stroke="@iconColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                            break;
                        case MyApp.Web.ViewModels.Components.SidebarIcon.Support:
                            @* Kulaklık *@
                            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;">
                                <path d="M3 9.75V9a6 6 0 0112 0v.75" stroke="@iconColor" stroke-width="1.5" stroke-linecap="round"/>
                                <path d="M3 9.75H3.75V14.25H3a1.5 1.5 0 01-1.5-1.5v-1.5A1.5 1.5 0 013 9.75z" stroke="@iconColor" stroke-width="1.5"/>
                                <path d="M15 9.75h-.75v4.5H15a1.5 1.5 0 001.5-1.5v-1.5A1.5 1.5 0 0015 9.75z" stroke="@iconColor" stroke-width="1.5"/>
                                <path d="M14.25 14.25a3 3 0 01-3 3H9.75" stroke="@iconColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                            break;
                        case MyApp.Web.ViewModels.Components.SidebarIcon.LiveSupport:
                            @* Sohbet balonu *@
                            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;">
                                <path d="M1.5 4.5a1.5 1.5 0 011.5-1.5h9a1.5 1.5 0 011.5 1.5v5.25a1.5 1.5 0 01-1.5 1.5H6L2.25 13.5V11.25h-.75A0 0 0 011.5 9.75V4.5z" stroke="@iconColor" stroke-width="1.5" stroke-linejoin="round"/>
                                <path d="M5.25 7.5h6M5.25 9.75h3.75" stroke="@iconColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                            break;
                        case MyApp.Web.ViewModels.Components.SidebarIcon.Invoices:
                            @* Fiş/makbuz *@
                            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;">
                                <path d="M3 1.5v15l2.25-1.5L7.5 16.5 9 15l1.5 1.5 2.25-1.5L15 16.5V1.5" stroke="@iconColor" stroke-width="1.5" stroke-linejoin="round"/>
                                <path d="M6 6.75h6M6 9.75h6M6 12.75h3" stroke="@iconColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                            break;
                        case MyApp.Web.ViewModels.Components.SidebarIcon.Contracts:
                            @* Belge + mühür *@
                            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;">
                                <path d="M3.75 1.5h10.5a.75.75 0 01.75.75v13.5a.75.75 0 01-.75.75H3.75a.75.75 0 01-.75-.75V2.25a.75.75 0 01.75-.75z" stroke="@iconColor" stroke-width="1.5"/>
                                <circle cx="9" cy="9" r="2.25" stroke="@iconColor" stroke-width="1.5"/>
                                <path d="M6 5.25h6M6 12.75h6" stroke="@iconColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                            break;
                        case MyApp.Web.ViewModels.Components.SidebarIcon.Settings:
                            @* Dişli çark *@
                            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;">
                                <circle cx="9" cy="9" r="2.25" stroke="@iconColor" stroke-width="1.5"/>
                                <path d="M9 1.5V3M9 15v1.5M1.5 9H3M15 9h1.5M3.46 3.46l1.06 1.06M13.48 13.48l1.06 1.06M13.48 4.52l1.06-1.06M3.46 14.54l1.06-1.06" stroke="@iconColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                            break;
                    }
                    <span style="@labelStyle">@item.Label</span>
                </a>
            }
        </nav>

        @* ── VIP Kartı ────────────────────────────────────────────── *@
        <div style="display:flex;flex-direction:column;align-items:flex-start;padding:0 8px;width:259px;height:116.19px;flex-shrink:0;">
            <div style="position:relative;width:243px;height:108.19px;background:linear-gradient(135deg,#1B4092 0%,#2E6DF8 100%);border-radius:14px;overflow:hidden;box-sizing:border-box;align-self:stretch;">

                @* Başlık satırı: taç ikonu + metin *@
                <div style="position:absolute;display:flex;flex-direction:row;align-items:center;gap:8px;width:219px;height:16px;left:12px;top:12px;">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0;">
                        <path d="M1.33 11.33L4 4l4 4 4-4 2.67 7.33z" stroke="#FFD700" stroke-width="1.33" stroke-linejoin="round" stroke-linecap="round"/>
                        <path d="M3.33 14h9.34" stroke="#FFD700" stroke-width="1.33" stroke-linecap="round"/>
                    </svg>
                    <span style="font-family:'Poppins';font-weight:700;font-size:12px;line-height:16px;color:#FFFFFF;">@Model.VipCard.Title</span>
                </div>

                @* Açıklama *@
                <p style="position:absolute;width:219px;left:12px;top:32px;margin:0;font-family:'Poppins';font-weight:300;font-size:11px;line-height:14px;color:rgba(255,255,255,0.75);">@Model.VipCard.Description</p>

                @* CTA butonu *@
                <a href="@Model.VipCard.ButtonHref"
                   style="position:absolute;display:flex;align-items:center;justify-content:center;width:219px;height:27.59px;left:12px;top:68.59px;background:#FFFFFF;border-radius:10px;text-decoration:none;">
                    <span style="font-family:'Poppins';font-weight:600;font-size:12px;line-height:16px;color:#0056B3;">@Model.VipCard.ButtonText</span>
                </a>

                @* Dekoratif arka plan ikonu *@
                <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"
                     style="position:absolute;left:195px;top:8px;opacity:0.1;">
                    <path d="M3.33 28.33L10 10l10 10 10-10 6.67 18.33z" stroke="#FFFFFF" stroke-width="3.33" stroke-linejoin="round" stroke-linecap="round"/>
                    <path d="M8.33 35h23.34" stroke="#FFFFFF" stroke-width="3.33" stroke-linecap="round"/>
                </svg>
            </div>
        </div>

        @* ── Tema değiştirici ─────────────────────────────────────── *@
        <div style="display:flex;flex-direction:column;align-items:flex-start;padding:9px 12px 0;width:259px;height:47px;border-top:1px solid rgba(46,109,248,0.1);box-sizing:border-box;flex-shrink:0;">
            <div style="display:flex;flex-direction:row;align-items:center;padding:3px;gap:2px;width:235px;height:30px;background:#DCE3FB;border-radius:9999px;">

                @* Açık tema *@
                <button type="button"
                        @@click="theme = 'light'"
                        :style="theme === 'light' ? 'background:#FFFFFF;box-shadow:0px 1px 3px rgba(0,0,0,0.1),0px 1px 2px -1px rgba(0,0,0,0.1);' : ''"
                        style="display:flex;justify-content:center;align-items:center;width:113.5px;height:24px;border-radius:9999px;border:none;cursor:pointer;background:transparent;transition:all 0.15s;">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="7" cy="7" r="2.33" stroke="#F59E0B" stroke-width="1.17"/>
                        <path d="M7 1.17V2.33M7 11.67V12.83M1.17 7H2.33M11.67 7H12.83M2.88 2.88l.82.82M10.3 10.3l.82.82M10.3 3.7l-.82.82M3.7 10.3l-.82.82" stroke="#F59E0B" stroke-width="1.17" stroke-linecap="round"/>
                    </svg>
                </button>

                @* Koyu tema *@
                <button type="button"
                        @@click="theme = 'dark'"
                        :style="theme === 'dark' ? 'background:#FFFFFF;box-shadow:0px 1px 3px rgba(0,0,0,0.1),0px 1px 2px -1px rgba(0,0,0,0.1);' : ''"
                        style="display:flex;justify-content:center;align-items:center;width:113.5px;height:24px;border-radius:9999px;border:none;cursor:pointer;background:transparent;transition:all 0.15s;">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12.25 7.58A5.25 5.25 0 016.42 1.75 5.25 5.25 0 1012.25 7.58z" stroke="#7A94B8" stroke-width="1.17" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>

            </div>
        </div>

    </div>
</div>
