@page "{id:int}"
@model MyApp.Web.Pages.Clients.DetailModel
@{
    ViewData["Title"] = "Müşteri Detay";
}

<div class="p-6">
    <a class="text-sm text-blue-600 hover:underline" asp-page="/Clients/Index">← Listeye dön</a>
    <div class="mt-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
        <h1 class="text-2xl font-medium text-gray-900">@Model.Entity!.FullName</h1>
        <p class="mt-2 text-gray-600">@Model.Entity.Email</p>
        <p class="mt-4 text-sm text-gray-500">Kayıt: @Model.Entity.JoinedDate</p>
        <span class="mt-4 inline-block rounded-full bg-gray-100 px-3 py-1 text-sm text-gray-800">@Model.Entity.StatusLabel</span>
    </div>
</div>
