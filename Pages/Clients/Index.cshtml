@page
@model MyApp.Web.Pages.Clients.IndexModel
@{
    ViewData["Title"] = "Müşteriler";
}

<div class="p-6">
    <h1 class="mb-6 text-2xl font-medium text-gray-900">Müşteriler</h1>

    <div class="mb-8">
        @await Component.InvokeAsync("ClientSummary", new { take = 5 })
    </div>

    <div class="divide-y divide-gray-200 rounded-xl border border-gray-200 bg-white">
        @foreach (var client in Model.Clients)
        {
            <div class="p-4">
                <partial name="~/Partials/_ClientCard.cshtml" model="client" />
            </div>
        }
    </div>
</div>
