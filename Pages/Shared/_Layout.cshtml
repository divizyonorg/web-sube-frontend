<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyApp.Web</title>
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-gray-50 text-gray-900 antialiased">
    <header class="border-b border-gray-200 bg-white shadow-sm">
        <nav class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-4 py-3">
            <a class="text-lg font-semibold text-gray-900" asp-page="/Index">MyApp.Web</a>
            <ul class="flex flex-wrap gap-4 text-sm">
                <li><a class="text-blue-600 hover:underline" asp-page="/Index">Ana Sayfa</a></li>
                <li><a class="text-blue-600 hover:underline" asp-page="/Clients/Index">Müşteriler</a></li>
                <li><a class="text-blue-600 hover:underline" asp-page="/Privacy">Gizlilik</a></li>
            </ul>
        </nav>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-8">
        @RenderBody()
    </main>

    <footer class="border-t border-gray-200 bg-white py-6 text-center text-sm text-gray-500">
        &copy; @DateTime.UtcNow.Year - MyApp.Web — <a class="text-blue-600 hover:underline" asp-page="/Privacy">Gizlilik</a>
    </footer>

    <script src="~/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
