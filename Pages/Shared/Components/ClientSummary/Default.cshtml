@model ClientSummaryViewModel
@{ Layout = null; }

<div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm space-y-4">
    <div class="flex items-center justify-between">
        <span class="text-sm text-gray-500">Toplam Müşteri</span>
        <span class="text-2xl font-medium text-gray-900">@Model.TotalCount</span>
    </div>
    @foreach (var name in Model.RecentActiveNames)
    {
        <div class="flex items-center gap-2">
            <div class="h-2 w-2 rounded-full bg-green-400"></div>
            <span class="text-sm text-gray-800">@name</span>
        </div>
    }
</div>
