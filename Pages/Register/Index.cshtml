@page "/register"
@model MyApp.Web.Pages.Register.IndexModel
@{ Layout = null; }

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Üye Ol — İnteraktif Şube</title>
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; font-family: 'Poppins', sans-serif; }
        button { font-family: 'Poppins', sans-serif; }
        [x-cloak] { display: none !important; }
    </style>
</head>
<body>

    <div x-data="registerForm()" class="flex h-screen overflow-hidden">

        @* ── Sol panel — yalnızca desktop ── *@
        <div class="hidden lg:block relative w-[44.4%] shrink-0 overflow-hidden bg-linear-to-b from-[#071B55] via-[#0A2468] to-[#0D3080]">

            <div class="absolute -bottom-15 left-1/2 -translate-x-1/2 w-130 h-130 rounded-full pointer-events-none z-1"
                 style="background:radial-gradient(circle, rgba(30,130,255,0.30) 0%, rgba(20,100,220,0.18) 40%, transparent 70%);"></div>
            <div class="absolute -bottom-10 left-1/2 -translate-x-1/2 w-95 h-95 rounded-full border-[1.5px] border-[rgba(100,180,255,0.20)] pointer-events-none z-1"></div>
            <div class="absolute left-7.5 bottom-80 w-37.5 h-37.5 rotate-45 border-[1.5px] border-[rgba(80,160,255,0.30)] rounded-md pointer-events-none z-2"></div>
            <div class="absolute right-2.5 bottom-92.5 w-30 h-30 rotate-45 border-[1.5px] border-[rgba(80,160,255,0.22)] rounded-[5px] pointer-events-none z-2"></div>
            <div class="absolute left-12.5 bottom-42.5 w-32.5 h-32.5 rotate-45 border-[1.5px] border-[rgba(80,160,255,0.25)] rounded-[5px] pointer-events-none z-2"></div>
            <div class="absolute right-5 bottom-50 w-40 h-40 rotate-45 border-[1.5px] border-[rgba(80,160,255,0.20)] rounded-md pointer-events-none z-2"></div>
            <div class="absolute left-1/2 bottom-60 -translate-x-1/2 rotate-45 w-50 h-50 border-[1.5px] border-[rgba(100,180,255,0.15)] rounded-lg pointer-events-none z-1"></div>

            <div class="absolute top-0 left-0 right-0 h-[40%] z-5 flex items-center px-[52px]">
                <p class="font-semibold text-[28px] leading-[1.65] text-white m-0">
                    Kafana en çok takılan,<br>
                    bunu nasıl çözerim<br>
                    dediğin <span class="text-[#3AD7B3]">tüm finansal<br>
                    soruların</span> cevabını<br>
                    burada bulacaksın.
                </p>
            </div>

            <img src="~/images/register-image.jpg"
                 alt=""
                 class="absolute bottom-0 left-0 w-full h-[62%] object-cover object-center z-3" />
        </div>

        @* ── Sağ panel — scroll yok, içerik ortada ── *@
        <div class="flex-1 min-w-0 h-full flex flex-col items-center justify-center overflow-hidden bg-[#EEF2FB] px-4 py-3 lg:bg-white lg:px-6 lg:py-4">
            <div class="w-full max-w-[440px] flex flex-col items-center lg:max-w-[420px]">

                @* Logo 200×52 *@
                <img src="~/images/ik_logo.png"
                     alt="İnteraktif Kredi"
                     style="width:200px; height:52px; object-fit:contain;"
                     class="mb-3" />

                @* Kart *@
                <div class="w-full border-[1.5px] border-[#DCE3FB] rounded-2xl px-5 pt-4 pb-4 bg-white lg:px-7">
                    <form id="registerForm" method="post" class="flex flex-col space-y-4">
                        @Html.AntiForgeryToken()

                        @* Başlık *@
                        <div>
                            <p style="font-size:14px; font-weight:300; color:#374151; margin:0 0 4px 0;">Bireysel</p>
                            <h1 style="font-size:22px; font-weight:700; color:#0D2B6C; margin:0;">Hemen Üye Ol</h1>
                        </div>

                        @* Adın *@
                        <div class="[&>div]:w-full! [&_input]:w-full!">
                            <partial name="~/Partials/Components/_Input.cshtml"
                                     model='new InputViewModel { Label = "Adın", Type = InputFieldType.Text, Name = "FirstName", ContainerWidth = 364 }' />
                        </div>

                        @* Soyadın *@
                        <div class="[&>div]:w-full! [&_input]:w-full!">
                            <partial name="~/Partials/Components/_Input.cshtml"
                                     model='new InputViewModel { Label = "Soyadın", Type = InputFieldType.Text, Name = "LastName", ContainerWidth = 364 }' />
                        </div>

                        @* Mail *@
                        <div class="[&>div]:w-full! [&_input]:w-full!">
                            <partial name="~/Partials/Components/_Input.cshtml"
                                     model='new InputViewModel { Label = "Mail", Type = InputFieldType.Email, Name = "Email", ContainerWidth = 364 }' />
                        </div>

                        @* Doğum Tarihi *@
                        <div class="[&>div]:w-full! [&_input]:w-full!">
                            <partial name="~/Partials/Components/_Input.cshtml"
                                     model='new InputViewModel { Label = "Doğum Tarihin (GG/AA/YYYY)", Type = InputFieldType.Text, Name = "BirthDate", ContainerWidth = 364 }' />
                        </div>

                        @* 3 Ana checkbox *@
                        @{
                            var cbRiza  = new CheckboxViewModel {
                                Name      = "ConsentOpenRiza",
                                HtmlLabel = "İnteraktif Kredi <span style=\"font-weight:500; color:#0056B3; text-decoration:underline;\">Açık Rıza Metni</span>'ni okudum ve kişisel verilerimin işlenmesine onay veriyorum."
                            };
                            var cbAydin = new CheckboxViewModel {
                                Name      = "ConsentAydinlatma",
                                HtmlLabel = "İnteraktif Kredi <span style=\"font-weight:500; color:#0056B3; text-decoration:underline;\">Aydınlatma Metni</span>'ni okudum ve onaylıyorum."
                            };
                            var cbIleti = new CheckboxViewModel {
                                Name      = "ConsentIleti",
                                HtmlLabel = "İnteraktif Kredi tarafından ticari elektronik ileti gönderilmesini onay metni kapsamında kabul ediyorum."
                            };
                        }
                        <div class="flex flex-col gap-3">
                            <partial name="~/Partials/Components/_Checkbox.cshtml" model="cbRiza" />
                            <partial name="~/Partials/Components/_Checkbox.cshtml" model="cbAydin" />
                            <partial name="~/Partials/Components/_Checkbox.cshtml" model="cbIleti" />
                        </div>

                        @* İletişim kanalları *@
                        <div class="flex gap-5">

                            <div x-data="{ checked: false }" class="flex items-center gap-2">
                                <input type="checkbox" name="ConsentSms" x-model="checked" class="sr-only" />
                                <div @@click="checked = !checked"
                                     :class="checked ? 'bg-[#0056B3] border-[#0056B3]' : 'bg-white border-[#0056B3]'"
                                     class="w-4.5 h-4.5 border rounded-[4px] flex items-center justify-center shrink-0 cursor-pointer">
                                    <svg x-show="checked" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20 6L9 17L4 12"/>
                                    </svg>
                                </div>
                                <span @@click="checked = !checked" class="text-xs font-normal text-[#739FCC] select-none cursor-pointer">SMS</span>
                            </div>

                            <div x-data="{ checked: false }" class="flex items-center gap-2">
                                <input type="checkbox" name="ConsentEposta" x-model="checked" class="sr-only" />
                                <div @@click="checked = !checked"
                                     :class="checked ? 'bg-[#0056B3] border-[#0056B3]' : 'bg-white border-[#0056B3]'"
                                     class="w-4.5 h-4.5 border rounded-[4px] flex items-center justify-center shrink-0 cursor-pointer">
                                    <svg x-show="checked" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20 6L9 17L4 12"/>
                                    </svg>
                                </div>
                                <span @@click="checked = !checked" class="text-xs font-normal text-[#739FCC] select-none cursor-pointer">E-Posta</span>
                            </div>

                            <div x-data="{ checked: false }" class="flex items-center gap-2">
                                <input type="checkbox" name="ConsentArama" x-model="checked" class="sr-only" />
                                <div @@click="checked = !checked"
                                     :class="checked ? 'bg-[#0056B3] border-[#0056B3]' : 'bg-white border-[#0056B3]'"
                                     class="w-4.5 h-4.5 border rounded-[4px] flex items-center justify-center shrink-0 cursor-pointer">
                                    <svg x-show="checked" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20 6L9 17L4 12"/>
                                    </svg>
                                </div>
                                <span @@click="checked = !checked" class="text-xs font-normal text-[#739FCC] select-none cursor-pointer">Arama</span>
                            </div>

                        </div>

                        @* Üye Ol butonu *@
                        <div class="[&_button]:w-full!"
                             @@click="canSubmit() && submitForm()"
                             :class="canSubmit() ? 'cursor-pointer' : 'cursor-not-allowed opacity-50 pointer-events-none'">
                            <partial name="~/Partials/Components/_Button.cshtml"
                                     model='new ButtonViewModel { Label = "Üye Ol", Variant = ButtonVariant.Primary, Width = 364 }' />
                        </div>

                        @* Giriş linki *@
                        <p style="font-size:14px; color:#374151; text-align:center; margin:0;">
                            Zaten üye misin?
                            <a href="/login" class="font-semibold text-[#0056B3] no-underline ml-1">Giriş Yap</a>
                        </p>

                        @* Ayırıcı *@
                        <div class="h-px bg-[#E5E7EB]"></div>

                    </form>
                </div>

            </div>
        </div>

    </div>

    <script defer src="~/lib/alpinejs/cdn.min.js"></script>
    <script src="~/lib/imask/imask.min.js"></script>
    <script>
        function registerForm() {
            return {
                firstName: '',
                lastName: '',
                email: '',
                birthDate: '',

                init() {
                    var self = this;

                    var firstEl = document.getElementById('FirstName');
                    if (firstEl) firstEl.addEventListener('input', function () { self.firstName = firstEl.value.trim(); });

                    var lastEl = document.getElementById('LastName');
                    if (lastEl) lastEl.addEventListener('input', function () { self.lastName = lastEl.value.trim(); });

                    var emailEl = document.getElementById('Email');
                    if (emailEl) emailEl.addEventListener('input', function () { self.email = emailEl.value.trim(); });

                    var birthEl = document.getElementById('BirthDate');
                    if (birthEl) {
                        var dateMask = IMask(birthEl, { mask: '00/00/0000' });
                        dateMask.on('accept', function () { self.birthDate = dateMask.value; });
                    }
                },

                canSubmit() {
                    return this.firstName.length > 0
                        && this.lastName.length > 0
                        && this.email.length > 0
                        && this.birthDate.length === 10;
                },

                submitForm() {
                    document.getElementById('registerForm').submit();
                }
            };
        }
    </script>

</body>
</html>
